<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/card_background"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="12dp"
    android:paddingTop="10dp"
    android:paddingEnd="12dp"
    android:paddingBottom="10dp">

    <ImageView
        android:id="@+id/img_blue"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@mipmap/ic_blue_remote" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txt_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txt_mac"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_idle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone">

        <TextView
            android:id="@+id/txt_rssi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/rssi_amber"
            android:textSize="13sp"
            android:textStyle="bold" />

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginStart="4dp"
            android:src="@mipmap/ic_rssi" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_connect"
            style="@style/DeviceButton.Connect"
            android:layout_marginStart="8dp"
            android:text="@string/connect" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_connected"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/connected"
            android:textColor="@color/connected_green"
            android:textSize="12sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_disconnect"
            style="@style/DeviceButton.Disconnect"
            android:layout_marginStart="6dp"
            android:text="@string/disconnect" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_detail"
            style="@style/DeviceButton.Detail"
            android:layout_marginStart="6dp"
            android:text="@string/enter" />

    </LinearLayout>

</LinearLayout>
